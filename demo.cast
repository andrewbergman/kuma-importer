[0.012, "o", "kuma-importer demo\r\n==================\r\n"]
[1.509, "o", "\r\nStep 0: Show the interactive menu\r\n"]
[1.517, "o", "\r\n$ printf \"12\\n\" | python kuma_importer.py\r\n"]
[1.249, "o", "\r\nkuma-importer\r\n-------------\r\n1. Import from CSV\r\n2. Import from TXT\r\n3. Manual entry mode\r\n4. Manual entry mode using a defaults profile (clone defaults)\r\n5. Export existing monitors to CSV\r\n6. Export and verify current monitors\r\n7. Report unmanaged monitors\r\n8. Delete unmanaged monitors\r\n9. Delete selected monitors\r\n10. Delete all monitors\r\n"]
[0.000, "o", "11. Show loaded defaults profiles\r\n12. Quit\r\nSelect an option [1-12]: "]
[1.544, "o", "\r\nStep 1: Import monitors from CSV (real execution)\r\n"]
[1.524, "o", "\r\n$ python kuma_importer.py --csv example_monitors.csv --no-backup-before-apply\r\n"]
